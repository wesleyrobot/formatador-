# Copie este arquivo para .env e preencha os valores

# PostgreSQL local (desenvolvimento)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contactprocessor

# PostgreSQL Neon (produção) — copie a connection string do painel Neon:
# https://console.neon.tech → seu projeto → Connection Details → "Pooled connection"
# Formato: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL=postgresql://...

# Chave da API Google Gemini (gratuita em aistudio.google.com)
GEMINI_API_KEY=AIza...

# Origens permitidas para CORS (separadas por vírgula)
# Use * para desenvolvimento local, ou o domínio do Netlify em produção
ALLOWED_ORIGINS=*

# Pasta onde os ZIPs gerados são salvos temporariamente
STORAGE_DIR=/tmp/contactprocessor_zips
